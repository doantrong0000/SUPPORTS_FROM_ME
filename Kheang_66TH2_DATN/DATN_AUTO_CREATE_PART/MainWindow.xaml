<Window x:Class="DATN_AUTO_CREATE_PART.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DATN_AUTO_CREATE_PART"
        xmlns:viewmodels="clr-namespace:DATN_AUTO_CREATE_PART.ViewModels"
        mc:Ignorable="d"
        Title="Auto Create Part from CAD" Height="600" Width="800">
    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ToolBar / Header Area -->
        <Border Background="#F3F3F3" Padding="10" CornerRadius="5" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="CAD Commands:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0" Foreground="#555"/>
                    <Button Content="Scan Beams" Command="{Binding ScanCadBeamsCommand}" Width="100" Height="32" Margin="0,0,5,0" Background="#E1E1E1"/>
                    <Button Content="Scan Columns" Command="{Binding ScanCadColumnsCommand}" Width="100" Height="32" Margin="0,0,5,0" Background="#E1E1E1"/>
                    <Button Content="Scan Floors" Command="{Binding ScanCadFloorsCommand}" Width="100" Height="32" Margin="0,0,5,0" Background="#E1E1E1"/>
                      <Button Content="Set CAD Origin" Command="{Binding SetCadOriginCommand}" Width="110" Height="32" Margin="0,0,5,0" Background="#E1E1E1"/>
                  
                </StackPanel>          
          
        </Border>

        <TabControl Grid.Row="2">
            <TabItem Header="Beams">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5">
                        <TextBlock Text="Layer filter:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Text="{Binding BeamLayerFilter, UpdateSourceTrigger=PropertyChanged}" Width="300" ToolTip="Comma-separated keywords, e.g.: beam, dam, frame"/>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding BeamCollections}" AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mark/Text" Binding="{Binding Text}" Width="*"/>
                            <DataGridTextColumn Header="Width" Binding="{Binding Width}" Width="*"/>
                            <DataGridTextColumn Header="Height" Binding="{Binding Height}" Width="*"/>
                            <DataGridTextColumn Header="Count" Binding="{Binding Number}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="Columns">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5">
                        <TextBlock Text="Layer filter:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Text="{Binding ColumnLayerFilter, UpdateSourceTrigger=PropertyChanged}" Width="300" ToolTip="Comma-separated keywords, e.g.: col, cot, column"/>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding ColumnCollections}" AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="*"/>
                            <DataGridTextColumn Header="Count" Binding="{Binding Number}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="Floors">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5">
                        <TextBlock Text="Layer filter:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Text="{Binding FloorLayerFilter, UpdateSourceTrigger=PropertyChanged}" Width="300" ToolTip="Comma-separated keywords, e.g.: slab, san, floor"/>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding FloorCollections}" AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Area (m2)" Binding="{Binding Area}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Count" Binding="{Binding Number}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Thickness (mm)" Binding="{Binding Thickness, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="Grid">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Layer filter:" Grid.Row="0" Grid.Column="0" Margin="0,5"/>
                    <TextBox Text="{Binding GridLayerFilter, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1" Margin="0,5" ToolTip="Comma-separated keywords, e.g.: grid, axis, truc"/>

                    <TextBlock Text="Coordinate X:" Grid.Row="1" Grid.Column="0" Margin="0,5"/>
                    <TextBox Text="{Binding GridSettings.CoordinateX, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Margin="0,5"/>

                    <TextBlock Text="Coordinate Y:" Grid.Row="2" Grid.Column="0" Margin="0,5"/>
                    <TextBox Text="{Binding GridSettings.CoordinateY, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1" Margin="0,5"/>

                    <TextBlock Text="Coordinate Z (Levels):" Grid.Row="3" Grid.Column="0" Margin="0,5"/>
                    <TextBox Text="{Binding GridSettings.CoordinateZ, UpdateSourceTrigger=PropertyChanged}" Grid.Row="3" Grid.Column="1" Margin="0,5"/>

                    <TextBlock Text="Label X:" Grid.Row="4" Grid.Column="0" Margin="0,5"/>
                    <TextBox Text="{Binding GridSettings.LabelX, UpdateSourceTrigger=PropertyChanged}" Grid.Row="4" Grid.Column="1" Margin="0,5"/>

                    <TextBlock Text="Label Y:" Grid.Row="5" Grid.Column="0" Margin="0,5"/>
                    <TextBox Text="{Binding GridSettings.LabelY, UpdateSourceTrigger=PropertyChanged}" Grid.Row="5" Grid.Column="1" Margin="0,5"/>

                    <TextBlock Text="Label Z:" Grid.Row="6" Grid.Column="0" Margin="0,5"/>
                    <TextBox Text="{Binding GridSettings.LabelZ, UpdateSourceTrigger=PropertyChanged}" Grid.Row="6" Grid.Column="1" Margin="0,5"/>
                    
                    <Button Grid.Row="7" Grid.ColumnSpan="2" Content="Scan Grids" Command="{Binding ScanCadGridsCommand}" Width="150" Height="30" Margin="0,10,0,0" Background="#E1E1E1" HorizontalAlignment="Left"/>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,10,0,0">
            <Button Content="Set Tekla Origin" Command="{Binding SetTeklaOriginCommand}" Height="36" Background="#E1E1E1" FontWeight="Bold" Margin="0,0,10,0" Width="180"/>
            <Button Content="Create Grid" Command="{Binding GenerateGridToTeklaCommand}" Height="36" Background="#E1E1E1" FontWeight="Bold" Margin="0,0,10,0" Width="180"/>
            <Button Content="Create Elements" Command="{Binding GenerateComponentsToTeklaCommand}" Height="36" Background="#E1E1E1" FontWeight="Bold" Margin="0,0,10,0" Width="180"/>
        </StackPanel>

    </Grid>
</Window>
