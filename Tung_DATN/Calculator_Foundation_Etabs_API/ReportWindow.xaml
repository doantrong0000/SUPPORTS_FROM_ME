<Window x:Class="Calculator_Foundation_Etabs_API.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thuyết minh tính toán chi tiết" Height="750" Width="850" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"  Padding="15">
            <TextBlock Text="THUYẾT MINH" 
                       FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
        </Border>

        <!-- Report Content -->
        <!-- Using FlowDocumentScrollViewer to allow flexible and nice report generation later -->
        <FlowDocumentScrollViewer Grid.Row="1" Margin="20" x:Name="ReportViewer" Background="White">
            <FlowDocument FontFamily="Segoe UI" FontSize="14" PagePadding="40">
                <Paragraph FontSize="18" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,20">
                    BÁO CÁO KẾT QUẢ TÍNH TOÁN CỐT THÉP MÓNG BĂNG
                </Paragraph>
                
                <Paragraph>
                    <Run FontWeight="Bold">Tên móng:</Run> 
                    <Run x:Name="RunFoundationName">[Đang chờ dữ liệu]</Run>
                </Paragraph>
                <Paragraph>
                    <Run FontWeight="Bold">Kích thước tiết diện:</Run> 
                    <Run x:Name="RunDimensions">[Đang chờ dữ liệu]</Run>
                </Paragraph>
                
                <BlockUIContainer Margin="0,20,0,20">
                    <Separator/>
                </BlockUIContainer>

                <Paragraph FontSize="16" FontWeight="SemiBold">
                    1. Số liệu nội lực (Từ ETABS)
                </Paragraph>
                <Paragraph Margin="20,0,0,0">
                    - Mô-men âm lớn nhất (M Top): <Run x:Name="RunMTop">...</Run> kNm<LineBreak/>
                    - Mô-men dương lớn nhất (M Bot): <Run x:Name="RunMBot">...</Run> kNm
                </Paragraph>

                <Paragraph FontSize="16" FontWeight="SemiBold" Margin="0,15,0,0">
                    2. Kết quả tính toán thép dọc
                </Paragraph>
                <Paragraph Margin="20,0,0,0">
                    - Diện tích thép yêu cầu lớp trên (As Top): <Run x:Name="RunAsTop" FontWeight="Bold">...</Run> cm²<LineBreak/>
                    - Diện tích thép yêu cầu lớp dưới (As Bot): <Run x:Name="RunAsBot" FontWeight="Bold">...</Run> cm²
                </Paragraph>

                <Paragraph FontStyle="Italic" Foreground="Gray" Margin="0,40,0,0">
                    Ghi chú: Báo cáo này sẽ được sinh tự động và điền số liệu chi tiết từ kết quả tính toán.
                </Paragraph>
            </FlowDocument>
        </FlowDocumentScrollViewer>

        <!-- Bottom Action Bar -->
        <Border Grid.Row="2" Background="#F3F4F6" Padding="15" BorderThickness="0,1,0,0" BorderBrush="#E5E7EB">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Đóng" Width="100" Padding="8" Margin="0,0,15,0" FontWeight="Bold"  BorderBrush="#D1D5DB" Click="BtnClose_Click"/>
                <Button Content="Xuất PDF / In" Width="120" Padding="8"   FontWeight="Bold" BorderThickness="0" Click="BtnPrint_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
