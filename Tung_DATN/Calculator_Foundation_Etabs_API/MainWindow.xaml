<Window x:Class="Calculator_Foundation_Etabs_API.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Calculator_Foundation_Etabs_API.ViewModels"
        Title="Strip Footing Design Pro" Height="800" Width="1400" WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    
    <DockPanel>


        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- INPUT PANEL (TOP) -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
             

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 1. ETABS Settings -->
                    <GroupBox Grid.Column="0" Header="1. Thông số ETABS" Margin="0,0,15,0" Padding="15,10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Tên Tổ Hợp (Load Combo):" Margin="0,0,10,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <ComboBox Width="220" Padding="6" IsEditable="True" 
                                      ItemsSource="{Binding LoadCombos}" 
                                      Text="{Binding SelectedCombo, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 2. Vật liệu -->
                    <GroupBox Grid.Column="1" Header="2. Thông số Vật liệu" Margin="0,0,15,0" Padding="15,10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Bê tông:" Margin="0,0,10,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <ComboBox Width="120" ItemsSource="{Binding ConcreteGrades}" SelectedItem="{Binding SelectedConcrete}" Padding="6" Margin="0,0,20,0" VerticalAlignment="Center"/>
                            
                            <TextBlock Text="Mác Thép:" Margin="0,0,10,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <ComboBox Width="120" ItemsSource="{Binding RebarGrades}" SelectedItem="{Binding SelectedRebar}" Padding="6" VerticalAlignment="Center"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="KẾT NỐI" Command="{Binding RefreshCombosCommand}" 
                                FontWeight="Bold" FontSize="15" Padding="30,0" Width="180" Height="50" 
                                VerticalAlignment="Stretch" Margin="0,0,10,0" Cursor="Hand"/>
                        
                        <Button Content="TÍNH TOÁN" Command="{Binding CalculateCommand}" 
                                FontWeight="Bold" FontSize="15" Padding="30,0" Width="180" Height="50"  
                                VerticalAlignment="Stretch" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- VISUALIZATION PANEL (BOTTOM) -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="Danh sách móng trong dự án" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                
                <DataGrid ItemsSource="{Binding Foundations}" Grid.Row="1"
                         MinRowHeight="35" AutoGenerateColumns="False" CanUserAddRows="False" AlternatingRowBackground="#F9FAFB" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tên móng" Binding="{Binding Name}" Width="150" IsReadOnly="True"/>
                        <DataGridTextColumn Header="B (m)" Binding="{Binding B, StringFormat={}{0:F2}}" Width="80"/>
                        <DataGridTextColumn Header="Bd (m)" Binding="{Binding Bd, StringFormat={}{0:F2}}" Width="80"/>
                        <DataGridTextColumn Header="H (m)" Binding="{Binding H, StringFormat={}{0:F2}}" Width="80"/>
                        <DataGridTextColumn Header="Hd (m)" Binding="{Binding Hd, StringFormat={}{0:F2}}" Width="80"/>
                        <DataGridTextColumn Header="M Dầm Đầu" Binding="{Binding MBot_Start, StringFormat={}{0:F1}}" Width="85" IsReadOnly="True" Foreground="Gray"/>
                        <DataGridTextColumn Header="M Dầm Giữa" Binding="{Binding MTop_Mid, StringFormat={}{0:F1}}" Width="85" IsReadOnly="True" Foreground="Gray"/>
                        <DataGridTextColumn Header="M Dầm Cuối" Binding="{Binding MBot_End, StringFormat={}{0:F1}}" Width="85" IsReadOnly="True" Foreground="Gray"/>

                        <DataGridTextColumn Header="M Strip Đầu" Binding="{Binding MStrip_Start, StringFormat={}{0:F1}}" Width="85" IsReadOnly="True" Foreground="#3B82F6"/>
                        <DataGridTextColumn Header="M Strip Giữa" Binding="{Binding MStrip_Mid, StringFormat={}{0:F1}}" Width="85" IsReadOnly="True" Foreground="#3B82F6"/>
                        <DataGridTextColumn Header="M Strip Cuối" Binding="{Binding MStrip_End, StringFormat={}{0:F1}}" Width="85" IsReadOnly="True" Foreground="#3B82F6"/>

                        <DataGridTextColumn Header="M TỔNG Đầu" Binding="{Binding MTotal_Start, StringFormat={}{0:F1}}" Width="95" IsReadOnly="True" FontWeight="Bold" Foreground="#EF4444"/>
                        <DataGridTextColumn Header="M TỔNG Giữa" Binding="{Binding MTotal_Mid, StringFormat={}{0:F1}}" Width="95" IsReadOnly="True" FontWeight="Bold" Foreground="#EF4444"/>
                        <DataGridTextColumn Header="M TỔNG Cuối" Binding="{Binding MTotal_End, StringFormat={}{0:F1}}" Width="95" IsReadOnly="True" FontWeight="Bold" Foreground="#EF4444"/>
                        
                        <DataGridTextColumn Header="Q max" Binding="{Binding Q_Max, StringFormat={}{0:F1}}" Width="80" IsReadOnly="True" FontWeight="SemiBold"/>

    
                        <DataGridTextColumn Header="As Bot Đầu" Binding="{Binding AsBot_Start, StringFormat=N2}" IsReadOnly="True" Width="85"/>
                        <DataGridTextColumn Header="As Top Giữa" Binding="{Binding AsTop_Mid, StringFormat=N2}" IsReadOnly="True" Width="85"/>
                       
      
                        <DataGridTextColumn Header="As Bot Cuối" Binding="{Binding AsBot_End, StringFormat=N2}" IsReadOnly="True" Width="85"/>
                        <DataGridTextColumn Header="Asw (Đai)" Binding="{Binding Asw, StringFormat=N2}" IsReadOnly="True" Width="80" FontWeight="SemiBold"/>

                        <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="120"/>

                        <DataGridTemplateColumn Header="Thao tác" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="Xem chi tiết" Padding="8,4" Margin="0,0,5,0" Background="#3B82F6" Foreground="White" Click="BtnViewReport_Click" Cursor="Hand"/>
                                        <Button Content="In báo cáo" Padding="8,4" Background="#10B981" Foreground="White" Click="BtnPrintReport_Click" Cursor="Hand"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
