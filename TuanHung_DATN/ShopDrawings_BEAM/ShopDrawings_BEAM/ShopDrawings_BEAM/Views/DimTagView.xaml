<Window x:Class="ShopDrawings_BEAM.Views.DimTagView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShopDrawings_BEAM.Views"
        mc:Ignorable="d"
        Title="Bước 2: Cấu hình Tag &amp; Dimension" Height="500" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF" FontFamily="Segoe UI">
    <Window.Resources>
        <!-- Styles Chung -->
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="6,4,6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#222222"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        
        <Style TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#E0E0E0"/>
                    <Setter Property="Foreground" Value="#888888"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F5F5"/>
                    <Setter Property="BorderBrush" Value="#999999"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Wizard Header -->
            <RowDefinition Height="*"/>    <!-- Steps Content -->
            <RowDefinition Height="Auto"/> <!-- Wizard Footer -->
        </Grid.RowDefinitions>

        <!-- WIZARD HEADER -->
        <Border Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="0,0,0,15" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="SHOP DRAWING DẦM TỰ ĐỘNG" FontSize="18" FontWeight="Bold" Foreground="#111111" Margin="0,0,0,4"/>
                    <TextBlock Text="Quy trình từng bước hướng dẫn thiết lập cấu kiện, khung nhìn và chèn tag/dim thủ công." FontSize="12" Foreground="#666666" Margin="0"/>
                </StackPanel>

                <!-- Indicator bước -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border CornerRadius="12" Width="24" Height="24" BorderBrush="#CCCCCC" BorderThickness="1.5">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#FFFFFF"/>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="1" Foreground="#CCCCCC" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0"/>
                    </Border>
                    
                    <Line X1="0" Y1="12" X2="25" Y2="12" Stroke="#CCCCCC" StrokeThickness="1.5" Margin="8,0"/>

                    <Border CornerRadius="12" Width="24" Height="24" BorderBrush="#111111" BorderThickness="1.5">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#111111"/>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="2" Foreground="#FFFFFF" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- STEPS CONTENT -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Status alert -->
                <RowDefinition Height="*"/>    <!-- Config Grid -->
            </Grid.RowDefinitions>

            <!-- Status alert -->
            <Border Grid.Row="0" Background="#F0F4F8" BorderBrush="#D0DCE5" BorderThickness="1" Padding="12" Margin="0,0,0,15" CornerRadius="3">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✔" Foreground="#1F4E79" FontWeight="Bold" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Đã tạo thành công các khung nhìn dầm trong Revit!" FontWeight="Bold" Foreground="#1F4E79" Margin="0"/>
                        <TextBlock Text="Vui lòng thực hiện cấu hình các loại Ký hiệu (Tag) và Đường kích thước (Dim) để hoàn thiện bản vẽ." FontSize="11.5" Foreground="#556677" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Config Tag & Dim -->
            <GroupBox Grid.Row="1" Header="Bước 2: Cấu hình Ký hiệu &amp; Đường kích thước (Tagging &amp; Dimensioning)">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Trái -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Tag Thép dọc (Mặt cắt dọc):" FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{Binding RebarTags}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedLongitudinalMainRebarTag}" />

                        <TextBlock Text="Tag Thép đai (Mặt cắt dọc):" FontWeight="SemiBold" Margin="0,15,0,5"/>
                        <ComboBox ItemsSource="{Binding RebarTags}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedLongitudinalStirrupTag}" />

                        <TextBlock Text="Tag Thép đai (Mặt cắt ngang):" FontWeight="SemiBold" Margin="0,15,0,5"/>
                        <ComboBox ItemsSource="{Binding RebarTags}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedCrossSectionStirrupTag}" />
                    </StackPanel>

                    <!-- Phải -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Tag Thép dọc (Mặt cắt ngang / Multi-Rebar):" FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{Binding MultiRebarTags}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedCrossSectionMainRebarTag}" />

                        <TextBlock Text="Đường kích thước (Dimension Style):" FontWeight="SemiBold" Margin="0,15,0,5"/>
                        <ComboBox ItemsSource="{Binding DimensionTypes}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedDimType}" />

                        <!-- Nút chèn Tag & Dim -->
                        <Button Content="CHÈN TAG &amp; DIMENSION" Style="{StaticResource BtnPrimary}" Margin="0,32,0,0" Height="40" Click="BtnCreateTagsAndDims_Click"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- WIZARD FOOTER -->
        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="0,15,0,0" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Tiến trình -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,90,0">
                    <TextBlock Text="Tiến độ thực thi..." Foreground="#666666" Margin="0,0,0,4" FontSize="11" FontStyle="Italic"/>
                    <ProgressBar Height="8" Minimum="0" Maximum="100" Value="{Binding ProgressValue}" Background="#EEEEEE" Foreground="#333333" BorderThickness="0" />
                </StackPanel>

                <!-- Nút Cancel / Finish -->
                <Button Grid.Column="2" Content="Đóng" Width="90" Style="{StaticResource BtnSecondary}" Click="BtnCancel_Click"/>
                
                <!-- Nút Hoàn thành -->
                <Button Grid.Column="4" Content="Hoàn Thành" Width="120" Click="BtnFinish_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ProgressValue}" Value="100">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
