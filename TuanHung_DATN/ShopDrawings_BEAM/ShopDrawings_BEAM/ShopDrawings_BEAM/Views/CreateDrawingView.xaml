<Window x:Class="ShopDrawings_BEAM.Views.CreateDrawingView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShopDrawings_BEAM.Views"
        mc:Ignorable="d"
        Title="ShopDrawings - Thiết lập &amp; Tạo Bản Vẽ Dầm" Height="780" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF" FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Styles Chung -->
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="6,4,6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#222222"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button styles -->
        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#E0E0E0"/>
                    <Setter Property="Foreground" Value="#888888"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F5F5"/>
                    <Setter Property="BorderBrush" Value="#999999"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BtnOutline" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#111111"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#111111"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="BorderBrush" Value="#CCCCCC"/>
                    <Setter Property="Foreground" Value="#888888"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Wizard Header -->
            <RowDefinition Height="*"/>
            <!-- Steps Content -->
            <RowDefinition Height="Auto"/>
            <!-- Wizard Footer -->
        </Grid.RowDefinitions>

        <!-- WIZARD HEADER -->
        <Border Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="0,0,0,15" Margin="0,0,0,20">
            <Grid>
                <StackPanel>
                    <TextBlock Text="SHOP DRAWING DẦM TỰ ĐỘNG" FontSize="18" FontWeight="Bold" Foreground="#111111" Margin="0,0,0,4"/>
                    <TextBlock Text="Thiết lập các thông số khung nhìn, mẫu ký hiệu và triển khai bản vẽ dầm tự động." FontSize="12" Foreground="#666666" Margin="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- STEPS CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <!-- Spacer -->
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- VÙNG CHÍNH (MAIN AREA): HÌNH ẢNH MINH HỌA & CANVAS -->
            <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="#FDFDFD">
                <Grid ClipToBounds="True">
                    <!-- Hình ảnh minh họa làm nền -->
                    <Image Source="pack://application:,,,/ShopDrawings_BEAM;component/Views/DRAWING.png" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <!-- Canvas chứa các Combobox đặt bất kỳ để kéo thả sau -->
                    <Canvas Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

                        <!-- Card 1: Tag Thép Dọc (Mặt cắt dọc) -->
                        <Border Canvas.Left="478" Canvas.Top="10" Width="160" 
                                Background="#F7FFFFFF" BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="6" Padding="6">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Color="#111111" Opacity="0.1" ShadowDepth="1"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Tag Thép Dọc (MC dọc):" FontWeight="SemiBold" FontSize="10" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding RebarTags}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedLongitudinalMainRebarTag}" Height="24" FontSize="10"/>
                            </StackPanel>
                        </Border>

                        <!-- Card 2: Tag Thép Đai (Mặt cắt dọc) -->
                        <Border Canvas.Left="248" Canvas.Top="10" Width="160" 
                                Background="#F7FFFFFF" BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="6" Padding="6" HorizontalAlignment="Left" VerticalAlignment="Top">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Color="#111111" Opacity="0.1" ShadowDepth="1"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Tag Thép Đai (MC dọc):" FontWeight="SemiBold" FontSize="10" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding RebarTags}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedLongitudinalStirrupTag}" Height="24" FontSize="10"/>
                            </StackPanel>
                        </Border>

                        <!-- Card 3: Đường Kích Thước (Dim Style) -->
                        <Border Canvas.Left="356" Canvas.Top="318" Width="160" 
                                Background="#F7FFFFFF" BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="6" Padding="6" HorizontalAlignment="Left" VerticalAlignment="Top">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Color="#111111" Opacity="0.1" ShadowDepth="1"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Dim Style (Kích thước):" FontWeight="SemiBold" FontSize="10" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding DimensionTypes}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedDimType}" Height="24" FontSize="10"/>
                            </StackPanel>
                        </Border>

                        <!-- Card 4: Tag Thép Dọc (MC Ngang / Multi-Rebar) -->
                        <Border Canvas.Left="632" Canvas.Top="356" Width="170" 
                                Background="#F7FFFFFF" BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="6" Padding="6" HorizontalAlignment="Center" VerticalAlignment="Top">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Color="#111111" Opacity="0.1" ShadowDepth="1"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Tag Thép Dọc (MC ngang - Multi):" FontWeight="SemiBold" FontSize="10" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding MultiRebarTags}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedCrossSectionMainRebarTag}" Height="24" FontSize="10"/>
                            </StackPanel>
                        </Border>

                        <!-- Card 5: Tag Thép Đai (MC Ngang) -->
                        <Border Canvas.Left="632" Canvas.Top="430" Width="170" 
                                Background="#F7FFFFFF" BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="6" Padding="6" HorizontalAlignment="Center" VerticalAlignment="Top">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Color="#111111" Opacity="0.1" ShadowDepth="1"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Tag Thép Đai (MC ngang):" FontWeight="SemiBold" FontSize="10" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding RebarTags}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedCrossSectionStirrupTag}" Height="24" FontSize="10"/>
                            </StackPanel>
                        </Border>

                    </Canvas>
                </Grid>
            </Border>

            <!-- VÙNG PHỤ (SIDEBAR AREA): THIẾT LẬP TẠO VIEW -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,5,0">




                    <!-- 1.3 Thiết lập Sheet & View Templates -->
                    <GroupBox Header="Thiết lập bản vẽ &amp; khung nhìn" IsEnabled="{Binding HasSelectedBeam}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Khung tên (TitleBlock):" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding TitleBlocks}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedTitleBlock}" />

                            <TextBlock Text="Tỷ lệ bản vẽ (View Scale):" FontWeight="SemiBold" Margin="0,10,0,4"/>
                            <ComboBox ItemsSource="{Binding ViewScales}" SelectedItem="{Binding SelectedViewScale}" />

                            <TextBlock Text="Loại hình chiếu mặt cắt dọc (Section View Type):" FontWeight="SemiBold" Margin="0,10,0,4"/>
                            <ComboBox ItemsSource="{Binding SectionViewTypes}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedSectionViewType}" />

                            <TextBlock Text="Loại hình chiếu mặt cắt ngang (Detail View Type):" FontWeight="SemiBold" Margin="0,10,0,4"/>
                            <ComboBox ItemsSource="{Binding DetailViewTypes}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedDetailViewType}" />

                            <TextBlock Text="Kiểu cổng nhìn (Viewport Type) - Dọc:" FontWeight="SemiBold" Margin="0,10,0,4"/>
                            <ComboBox ItemsSource="{Binding ViewportTypes}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedLongitudinalViewportType}" />

                            <TextBlock Text="Kiểu cổng nhìn (Viewport Type) - Ngang:" FontWeight="SemiBold" Margin="0,10,0,4"/>
                            <ComboBox ItemsSource="{Binding ViewportTypes}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedCrossSectionViewportType}" />

                            <TextBlock Text="Mẫu hiển thị (Template) - Dọc:" FontWeight="SemiBold" Margin="0,10,0,4"/>
                            <ComboBox ItemsSource="{Binding ViewTemplates}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedLongitudinalViewTemplate}" />

                            <TextBlock Text="Mẫu hiển thị (Template) - Ngang:" FontWeight="SemiBold" Margin="0,10,0,4"/>
                            <ComboBox ItemsSource="{Binding ViewTemplates}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedSectionViewTemplate}" />
                        </StackPanel>
                    </GroupBox>

                    <!-- Hành động (Actions) -->
                    <GroupBox Header="Thực thi triển khai Shop Drawing">
                        <StackPanel>
                            <!-- Nút triển khai duy nhất -->
                            <Button x:Name="BtnExecute" Content="TRIỂN KHAI SHOP DRAWING" Style="{StaticResource BtnPrimary}" Height="40" Click="BtnExecute_Click"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- WIZARD FOOTER -->
        
    </Grid>
</Window>
